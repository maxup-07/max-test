<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Max - Better than other</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body{margin:0;font-family:Poppins;background:#f4f6f9;}
header{background:#0f172a;color:#fff;text-align:center;padding:15px;}
.tag{font-size:13px;color:#cbd5f5;}

.filters{display:flex;gap:8px;overflow:auto;padding:10px;}
.filters button{border:none;padding:8px 14px;border-radius:20px;background:#e2e8f0;}
.filters button.active{background:#2563eb;color:#fff;}

.products{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;padding:10px;}
.card{background:#fff;border-radius:12px;padding:10px;box-shadow:0 2px 8px rgba(0,0,0,0.1);transition:.2s;}
.card:hover{transform:scale(1.03);}
.card img{width:100%;border-radius:10px;}

.add{background:#2563eb;color:#fff;border:none;padding:8px;width:100%;border-radius:6px;margin-top:5px;}

.cart-btn{position:fixed;bottom:20px;right:20px;background:#2563eb;color:#fff;padding:15px;border-radius:50%;font-size:18px;}
.whatsapp{position:fixed;bottom:80px;right:20px;background:#25D366;color:#fff;padding:12px;border-radius:50%;}

.cart-modal{position:fixed;bottom:0;width:100%;background:#fff;max-height:85%;overflow:auto;display:none;padding:15px;border-top-left-radius:15px;border-top-right-radius:15px;}
.cart-item{display:flex;justify-content:space-between;margin:10px 0;border-bottom:1px solid #eee;padding-bottom:5px;}
.qty button{padding:5px;}
.total{font-weight:600;margin-top:10px;}

input,textarea{width:100%;padding:8px;margin-top:5px;border-radius:6px;border:1px solid #ccc;}
button.submit{background:#16a34a;color:#fff;border:none;padding:10px;margin-top:10px;border-radius:6px;width:100%;}
.success{color:green;font-weight:600;text-align:center;margin-top:10px;}
</style>
</head>

<body>

<header>
<h2>Max</h2>
<div class="tag">Better than other | Varanasi, UP</div>
</header>

<div class="filters">
<button class="active" onclick="filter('All')">All</button>
<button onclick="filter('Groceries')">Groceries</button>
<button onclick="filter('Dairy')">Dairy</button>
<button onclick="filter('Snacks')">Snacks</button>
<button onclick="filter('Beverages')">Beverages</button>
</div>

<div class="products" id="products"></div>

<div class="cart-btn" onclick="toggleCart()">🛒 <span id="count">0</span></div>
<a class="whatsapp" href="https://wa.me/918929943187" target="_blank">💬</a>

<div class="cart-modal" id="cartModal">
<h3>Your Cart</h3>
<div id="cartItems"></div>
<div class="total">Total: ₹<span id="total">0</span></div>

<form action="https://formspree.io/f/mnjovvnl" method="POST" onsubmit="prepareOrder()">
<input type="hidden" name="order" id="orderData">

<input name="name" required placeholder="Your Name">
<input name="phone" required placeholder="Phone Number">
<textarea name="address" required placeholder="Delivery Address"></textarea>
<textarea name="notes" placeholder="Special Instructions"></textarea>

<button class="submit" type="submit">Place Order</button>
</form>

<div class="success" id="msg"></div>
</div>

<script>
const data=[
{name:"Aashirvaad Atta (5kg)",price:280,cat:"Groceries",img:"https://i.ibb.co/8X1sZrT/atta.jpg"},
{name:"Basmati Rice (5kg)",price:450,cat:"Groceries",img:"https://i.ibb.co/jfJ9t6g/rice.jpg"},
{name:"Amul Butter (500g)",price:280,cat:"Dairy",img:"https://i.ibb.co/ZV6WcXk/butter.jpg"},
{name:"Milk (1L)",price:60,cat:"Dairy",img:"https://i.ibb.co/5KkW9YF/milk.jpg"},
{name:"Lays Chips",price:20,cat:"Snacks",img:"https://i.ibb.co/4dQw0bW/lays.jpg"},
{name:"Biscuits Pack",price:30,cat:"Snacks",img:"https://i.ibb.co/m9hB1Yd/biscuit.jpg"},
{name:"Coca Cola (1L)",price:60,cat:"Beverages",img:"https://i.ibb.co/YR6X9YV/coke.jpg"},
{name:"Real Juice",price:120,cat:"Beverages",img:"https://i.ibb.co/Y7R1N9F/juice.jpg"},
{name:"Maggi Noodles",price:14,cat:"Snacks",img:"https://i.ibb.co/2s9Jv8z/maggi.jpg"},
{name:"Dairy Milk Chocolate",price:40,cat:"Snacks",img:"https://i.ibb.co/6g6nZyW/dairy.jpg"}
];

let cart=JSON.parse(localStorage.getItem("cart"))||[];

function show(list){
document.getElementById("products").innerHTML=list.map((p,i)=>`
<div class="card">
<img src="${p.img}" loading="lazy" alt="${p.name}">
<h4>${p.name}</h4>
<p>₹${p.price}</p>
<button class="add" onclick="add(${i})">Add to Cart</button>
</div>`).join("");
}

function filter(cat){
document.querySelectorAll(".filters button").forEach(b=>b.classList.remove("active"));
event.target.classList.add("active");
show(cat==="All"?data:data.filter(p=>p.cat===cat));
}

function add(i){
let f=cart.find(x=>x.name===data[i].name);
if(f)f.qty++; else cart.push({...data[i],qty:1});
save();
}

function save(){
localStorage.setItem("cart",JSON.stringify(cart));
update();
}

function update(){
document.getElementById("count").innerText=cart.reduce((a,b)=>a+b.qty,0);

let html="",total=0;
cart.forEach((c,i)=>{
total+=c.price*c.qty;
html+=`<div class="cart-item">
<div>${c.name}<br>₹${c.price*c.qty}</div>
<div class="qty">
<button onclick="chg(${i},-1)">-</button>
${c.qty}
<button onclick="chg(${i},1)">+</button>
</div>
</div>`;
});

document.getElementById("cartItems").innerHTML=html;
document.getElementById("total").innerText=total;
}

function chg(i,v){
cart[i].qty+=v;
if(cart[i].qty<=0)cart.splice(i,1);
save();
}

function toggleCart(){
let m=document.getElementById("cartModal");
m.style.display=m.style.display==="block"?"none":"block";
}

function prepareOrder(){
let txt="Order Details:\n";
cart.forEach(i=>txt+=`${i.name} x${i.qty} = ₹${i.qty*i.price}\n`);
txt+="Total ₹"+document.getElementById("total").innerText;

document.getElementById("orderData").value=txt;

cart=[];
localStorage.removeItem("cart");

setTimeout(()=>document.getElementById("msg").innerText="Order placed! Max will contact you on WhatsApp to confirm.",500);
}

show(data);
update();
</script>

</body>
</html>
